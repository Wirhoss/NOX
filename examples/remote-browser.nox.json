{
  "$schema": "https://raw.githubusercontent.com/Wirhoss/NOX/main/schemas/nox-config.json",
  "browser": {
    "wsEndpoint": "ws://localhost:3000/playwright",
    "headless": true
  },
  "jobs": [
    {
      "name": "scrape-remotely",
      "urls": ["https://example.com"],
      "actions": [
        { "type": "wait", "value": 2000 },
        { "type": "screenshot" }
      ],
      "selectors": [
        {
          "name": "heading",
          "selector": "h1",
          "extract": "text"
        }
      ]
    }
  ],
  "output": {
    "dir": "./output",
    "format": "json",
    "pretty": true
  }
}
