{
  "name": "nox",
  "version": "1.0.0",
  "type": "module",
  "description": "NOX — Web data extraction with Playwright + TypeScript + Bun",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun run --bun tsc",
    "typecheck": "tsc --noEmit",
    "scrape": "bun run src/index.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Wirhoss/NOX.git"
  },
  "keywords": ["playwright", "scraping", "typescript", "bun", "web-extraction"],
  "author": "Wirhoss",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Wirhoss/NOX/issues"
  },
  "homepage": "https://github.com/Wirhoss/NOX#readme",
  "dependencies": {
    "@playwright/test": "^1.60.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
